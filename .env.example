# --- Browser-side Supabase (consumed by supabase-js in src/) ---
# VITE_SUPABASE_URL must be an HTTP(s) PostgREST URL, NOT postgresql://.
# For a local stack: http://127.0.0.1:54321  (run `npx supabase status` to confirm)
VITE_SUPABASE_URL=SUPABASE_URL_PLACEHOLDER
VITE_SUPABASE_ANON_KEY=SUPABASE_ANON_KEY_PLACEHOLDER

# --- Server / tooling Supabase (consumed by scripts/db-migrate.mjs) ---
# Raw Postgres connection string. For a local stack:
#   postgresql://postgres:postgres@127.0.0.1:54322/postgres
SUPABASE_DB_URL=SUPABASE_DB_URL_PLACEHOLDER

# --- Gemini (currently client-side; server-side migration tracked in #12) ---
VITE_GEMINI_API_KEY=GEMINI_API_KEY_PLACEHOLDER
